# =============================================================================
# India Runs — Redrob Hackathon  |  .gitignore
# =============================================================================

# ── Large data files (too big for GitHub) ────────────────────────────────────
candidates.jsonl
candidates.jsonl.gz
*.jsonl.gz

# ── Python bytecode ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── macOS artifacts ───────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
__MACOSX/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
Thumbs.db
